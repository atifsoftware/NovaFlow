{
    "name": "novaflow/framework",
    "description": "A lightweight, high-performance PHP MVC framework with premium admin panel",
    "type": "project",
    "keywords": [
        "php",
        "framework",
        "mvc",
        "novaFlow",
        "admin-panel"
    ],
    "license": "MIT",
    "homepage": "https://novaflow.dev",
    "authors": [
        {
            "name": "NovaFlow Team",
            "email": "team@novaflow.dev",
            "homepage": "https://novaflow.dev"
        }
    ],
    "support": {
        "email": "support@novaflow.dev",
        "issues": "https://github.com/novaflow/framework/issues",
        "wiki": "https://novaflow.dev/docs",
        "source": "https://github.com/novaflow/framework"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "NovaFlow\\Core\\": "app/libraries/",
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "post-root-package-install": [
            "cp .env.example .env"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
